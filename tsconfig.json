{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",

    "lib": ["ES2020", "DOM"],

    "moduleResolution": "Bundler",
    "strict": true,

    "paths": {
      "@/*": ["./src/*"]
    },

    "types": ["vite/client"]
  },

  "include": ["src/**/*.ts", "src/**/*.d.ts", "src/**/*.vue"]
}
